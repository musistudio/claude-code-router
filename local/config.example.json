{
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "local-dev-key",
  "LOG": true,
  "LOG_LEVEL": "info",
  "API_TIMEOUT_MS": 600000,
  "_comment_providers": "xfyun uses Anthropic wire protocol, deepseek uses OpenAI wire protocol",
  "Providers": [
    {
      "name": "xfyun",
      "api_base_url": "https://maas-coding-api.cn-huabei-1.xfyun.cn/v1/messages",
      "api_key": "$XFYUN_API_KEY",
      "models": [
        "astron-code-latest"
      ],
      "transformer": {
        "use": [
          "Anthropic"
        ]
      }
    },
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com/chat/completions",
      "api_key": "$DEEPSEEK_API_KEY",
      "models": [
        "deepseek-v4-flash",
        "deepseek-v4-pro"
      ],
      "transformer": {
        "use": [
          "deepseek"
        ],
        "deepseek-v4-flash": {
          "use": [
            "tooluse"
          ]
        },
        "deepseek-v4-pro": {
          "use": [
            "reasoning",
            "tooluse"
          ]
        }
      }
    }
  ],
  "_comment_router": "Claude Code sends model names like claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5. CCR routes these to our actual providers.",
  "Router": {
    "default": "xfyun,astron-code-latest",
    "background": "deepseek,deepseek-v4-flash",
    "think": "deepseek,deepseek-v4-pro",
    "longContext": "xfyun,astron-code-latest",
    "longContextThreshold": 60000
  },
  "_comment_model_mapping": "KEY INNOVATION: Maps Claude Code native model names to CCR provider,model pairs. This is how Claude Code thinks it is talking to real Claude models while CCR transparently routes to xfyun/deepseek.",
  "ModelMapping": {
    "claude-opus-4-6": "deepseek,deepseek-v4-pro",
    "claude-opus-4-20250514": "deepseek,deepseek-v4-pro",
    "claude-opus-4": "deepseek,deepseek-v4-pro",
    "opus": "deepseek,deepseek-v4-pro",
    "claude-sonnet-4-6": "xfyun,astron-code-latest",
    "claude-sonnet-4-20250514": "xfyun,astron-code-latest",
    "claude-sonnet-4": "xfyun,astron-code-latest",
    "sonnet": "xfyun,astron-code-latest",
    "claude-haiku-4-5-20251213": "deepseek,deepseek-v4-flash",
    "claude-haiku-4-5": "deepseek,deepseek-v4-flash",
    "haiku": "deepseek,deepseek-v4-flash",
    "astron-code-latest": "xfyun,astron-code-latest"
  },
  "Concurrency": {
    "global": 8,
    "providers": {
      "xfyun": 2,
      "deepseek": 4
    },
    "queueTimeoutMs": 120000
  },
  "Storage": {
    "postgresUrl": "postgres://proxy:proxy@127.0.0.1:55432/proxy_local",
    "semanticStore": {
      "enabled": true,
      "embeddingModel": "nomic-embed-text",
      "embeddingEndpoint": "http://127.0.0.1:11434/api/embed",
      "dimension": 1536
    }
  },
  "_comment_fallback": "If xfyun fails, try deepseek. If deepseek fails, try xfyun. Never leave Claude Code hanging.",
  "fallback": {
    "default": [
      "deepseek,deepseek-v4-flash"
    ],
    "think": [
      "xfyun,astron-code-latest"
    ],
    "longContext": [
      "deepseek,deepseek-v4-pro"
    ]
  }
}