{
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "local-dev-key",
  "LOG": true,
  "LOG_LEVEL": "info",
  "API_TIMEOUT_MS": 600000,

  "_comment": "Pluggable provider architecture: add any OpenAI/Anthropic/Gemini compatible provider below. No provider-specific hardcoding.",

  "Providers": [
    {
      "name": "openai",
      "api_base_url": "https://api.openai.com/v1/chat/completions",
      "api_key": "${OPENAI_API_KEY}",
      "models": ["gpt-4o", "gpt-4o-mini", "o1", "o3-mini"],
      "transformer": {
        "use": ["openai"],
        "o1": { "use": ["openai", "reasoning"] },
        "o3-mini": { "use": ["openai", "reasoning"] }
      }
    },
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com/chat/completions",
      "api_key": "${DEEPSEEK_API_KEY}",
      "models": ["deepseek-chat", "deepseek-reasoner"],
      "transformer": {
        "use": ["deepseek"],
        "deepseek-reasoner": { "use": ["deepseek", "reasoning"] }
      }
    },
    {
      "name": "gemini",
      "api_base_url": "https://generativelanguage.googleapis.com/v1beta",
      "api_key": "${GEMINI_API_KEY}",
      "models": ["gemini-2.5-pro", "gemini-2.5-flash"],
      "transformer": { "use": ["gemini"] }
    },
    {
      "name": "ollama",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "ollama",
      "models": ["qwen2.5-coder:7b", "deepseek-coder-v2:16b"],
      "transformer": { "use": ["openai"] }
    }
  ],

  "Router": {
    "default": "openai,gpt-4o",
    "background": "openai,gpt-4o-mini",
    "think": "deepseek,deepseek-reasoner",
    "longContext": "openai,gpt-4o",
    "longContextThreshold": 60000,
    "reasoningFlash": "openai,gpt-4o-mini",
    "reasoningProMax": "deepseek,deepseek-reasoner"
  },

  "ModelMapping": {
    "claude-opus-4-6": "deepseek,deepseek-reasoner",
    "claude-opus-4-20250514": "deepseek,deepseek-reasoner",
    "claude-opus-4": "deepseek,deepseek-reasoner",
    "opus": "deepseek,deepseek-reasoner",
    "claude-sonnet-4-6": "openai,gpt-4o",
    "claude-sonnet-4-20250514": "openai,gpt-4o",
    "claude-sonnet-4": "openai,gpt-4o",
    "sonnet": "openai,gpt-4o",
    "claude-haiku-4-5-20251213": "openai,gpt-4o-mini",
    "claude-haiku-4-5": "openai,gpt-4o-mini",
    "haiku": "openai,gpt-4o-mini"
  },

  "Concurrency": {
    "global": 10,
    "providers": {
      "openai": 5,
      "deepseek": 5,
      "gemini": 3,
      "ollama": 2
    },
    "queueTimeoutMs": 120000
  },

  "fallback": {
    "default": ["deepseek,deepseek-chat"],
    "think": ["openai,gpt-4o"],
    "longContext": ["deepseek,deepseek-reasoner"]
  }
}
