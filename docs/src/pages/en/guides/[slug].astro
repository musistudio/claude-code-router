---
import DocPage from "../../../components/DocPage.astro";
import { enGuideDocs, sectionSlugFromPath } from "../../../section-docs";

export function getStaticPaths() {
  const activeLabels: Record<string, string> = {
    install: "Install And Start CCR",
    cli: "CLI Installation And Reference",
    docker: "Docker Deployment",
    provider: "Add A Provider",
    "agent-profile": "Connect Agent Profiles",
    observability: "Logs & Observability",
  };

  return Object.entries(enGuideDocs).map(([filePath, mod]) => {
    const slug = sectionSlugFromPath(filePath);

    return {
      params: { slug },
      props: { mod, activeSidebarItem: activeLabels[slug] },
    };
  });
}

const { mod, activeSidebarItem } = Astro.props;
---

<DocPage locale="en" pageKey="guides" doc={mod} activeSidebarItem={activeSidebarItem} />
