---
import DocPage from "../../../components/DocPage.astro";
import { agentClawSlugFromPath, enAgentClawDocs } from "../../../agentclaw-docs";
import { pageKeyFromSlug } from "../../../docs-structure";

export function getStaticPaths() {
  return Object.entries(enAgentClawDocs).map(([filePath, mod]) => {
    const slug = agentClawSlugFromPath(filePath);

    return {
      params: { slug },
      props: {
        mod,
        activeSidebarItem: pageKeyFromSlug("agentclaw", "en", slug),
      },
    };
  });
}

const { mod, activeSidebarItem } = Astro.props;
---

<DocPage locale="en" pageKey="agentclaw" doc={mod} activeSidebarItem={activeSidebarItem} />
