---
const target = "/en/configuration/providers/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline>
      window.location.replace("/en/configuration/providers/");
    </script>
  </head>
  <body>
    <a href={target}>Provider Config</a>
  </body>
</html>
