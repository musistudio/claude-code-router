---
import DocPage from "../../components/DocPage.astro";
import { agentClawSlugFromPath, zhAgentClawDocs } from "../../agentclaw-docs";
import { pageKeyFromSlug } from "../../docs-structure";

export function getStaticPaths() {
  return Object.entries(zhAgentClawDocs).map(([filePath, mod]) => {
    const slug = agentClawSlugFromPath(filePath);

    return {
      params: { slug },
      props: {
        mod,
        activeSidebarItem: pageKeyFromSlug("agentclaw", "zh", slug),
      },
    };
  });
}

const { mod, activeSidebarItem } = Astro.props;
---

<DocPage locale="zh" pageKey="agentclaw" doc={mod} activeSidebarItem={activeSidebarItem} />
