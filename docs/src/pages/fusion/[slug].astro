---
import DocPage from "../../components/DocPage.astro";
import { docModule, docPages, urlSlugFromPath } from "../../docs-structure";

export function getStaticPaths() {
  const fusionPages = docPages.filter(
    (page) => page.section === "fusion" && page.key !== "fusion"
  );

  return fusionPages.map((page) => ({
    params: { slug: urlSlugFromPath(page.path.zh) },
    props: { mod: docModule("zh", page.source.zh), activeSidebarItem: page.key },
  }));
}

const { mod, activeSidebarItem } = Astro.props;
---

<DocPage locale="zh" pageKey="fusion" doc={mod} activeSidebarItem={activeSidebarItem} />
