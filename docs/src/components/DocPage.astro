---
import DocsLayout from "../layouts/DocsLayout.astro";
import { docsContent, type DocPageKey, type Locale } from "../i18n/content";
import {
  docModule,
  docSections,
  getPage,
  getPrevNext,
  getSection,
  resolveSidebarGroups,
  sectionIndexSource,
} from "../docs-structure";
import { Check, ChevronDown, Copy, List } from "lucide-astro";

interface Props {
  locale: Locale;
  pageKey?: DocPageKey;
  doc?: any;
  activeSidebarItem?: string;
}

const {
  locale,
  pageKey = "documentation",
  doc: docProp,
  activeSidebarItem: activeSidebarItemProp,
} = Astro.props;
const content = docsContent[locale];
const section = getSection(pageKey);
const sectionDoc = docModule(locale, sectionIndexSource(section)[locale]);
const sectionHref = section.navPath[locale] ?? (locale === "en" ? "/en/" : "/");
const isSectionDoc = !docProp || docProp === sectionDoc;
const doc = docProp ?? sectionDoc;
const { Content, frontmatter } = doc;
const allHeadings = doc.getHeadings();
const tocHeadings = allHeadings.filter((heading) => heading.depth >= 2 && heading.depth <= 5);
const isExplicitHref = (value: string) =>
  value.startsWith("#") ||
  value.startsWith("/") ||
  value.startsWith("//") ||
  /^[a-z][a-z\d+.-]*:/i.test(value);

const getHeadingLinks = (targetDoc: any, baseHref: string, useLocalHashes: boolean) => {
  const links = new Map<string, string>();

  for (const heading of targetDoc.getHeadings()) {
    if (!links.has(heading.text)) {
      links.set(
        heading.text,
        useLocalHashes ? `#${heading.slug}` : `${baseHref}#${heading.slug}`
      );
    }
  }

  return links;
};
const sectionHeadingLinks = getHeadingLinks(sectionDoc, sectionHref, isSectionDoc);
const githubSlugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/[^\p{L}\p{N}\p{M}\s_-]/gu, "")
    .replace(/\s+/g, "-");
const resolveDocTarget = (target?: string, headingLinks = sectionHeadingLinks, baseHref = sectionHref) => {
  if (!target) return baseHref;
  if (isExplicitHref(target)) return target;
  return headingLinks.get(target) ?? `${baseHref}#${githubSlugify(target)}`;
};
const navItems = content.navItems.map((item) => {
  return {
    ...item,
    active: item.pageKey === pageKey,
  };
});
// The active top tab follows the section the current page belongs to:
// documentation/guides share the "docs" tab; feature sections use their feature key.
const activeFeatureKey = section.feature?.key ?? "docs";
const featuredNavItems = (content.featureNavItems ?? navItems).map((item) => ({
  ...item,
  active: item.featureKey ? item.featureKey === activeFeatureKey : item.active,
}));
const pageGroups = resolveSidebarGroups(pageKey, locale);
const pageSidebarGroups = pageGroups.map((group) => {
  const activeKey = activeSidebarItemProp
    ? group.items.some((item) => item.key === activeSidebarItemProp)
      ? activeSidebarItemProp
      : ""
    : group.activeItem ?? "";

  return {
    label: group.label,
    icon: group.icon,
    items: group.items.map((item) => item.label),
    active: group.items.find((item) => item.key === activeKey)?.label ?? "",
  };
});
const sidebarLinks = Object.fromEntries(
  pageGroups.flatMap((group) =>
    group.items.map((item) => [item.label, item.path ?? resolveDocTarget(item.label)])
  )
);
const useSectionOnlySidebar = Boolean(section.standalone);
const sidebarTreeSections = docSections.filter((treeSection) => treeSection.inSidebarTree);
const buildSectionTree = (
  treeSections: typeof docSections,
  options: { openCurrent: boolean; useLocalHashes: boolean }
) => treeSections.map((treeSection) => {
  const treeSectionDoc = docModule(locale, sectionIndexSource(treeSection)[locale]);
  const navHref = treeSection.navPath[locale] ?? "#";
  const navActive = treeSection.key === pageKey;
  const isCurrentSectionIndex = navActive && isSectionDoc;
  const navHeadingLinks = getHeadingLinks(
    treeSectionDoc,
    navHref,
    options.useLocalHashes && isCurrentSectionIndex
  );

  return {
    label: treeSection.navLabel[locale],
    href: navHref,
    active: navActive,
    open: options.openCurrent && navActive,
    groups: resolveSidebarGroups(treeSection.key, locale).map((group) => ({
      label: group.label,
      icon: group.icon,
      active: navActive && (group.activeItem ?? ""),
      items: group.items.map((item) => ({
        label: item.label,
        href: item.path ?? resolveDocTarget(item.label, navHeadingLinks, navHref),
        active:
          navActive &&
          (activeSidebarItemProp
            ? activeSidebarItemProp === item.key
            : // On a section index page only the directory link is highlighted.
              !isCurrentSectionIndex && group.activeItem === item.key),
        children: [],
      })),
    })),
  };
});
const sidebarTree = useSectionOnlySidebar
  ? []
  : buildSectionTree(sidebarTreeSections, { openCurrent: true, useLocalHashes: true });
const tocItems = tocHeadings.map((heading) => ({
  label: heading.text,
  href: `#${heading.slug}`,
  depth: heading.depth,
}));
const currentPageKey = activeSidebarItemProp ?? pageKey;
const currentPage = getPage(currentPageKey);
const { prev: prevPageDef, next: nextPageDef } = getPrevNext(currentPageKey);
const toPageNavLink = (page?: { label: Record<Locale, string>; path: Record<Locale, string> }) =>
  page ? { label: page.label[locale], href: page.path[locale] } : undefined;
const prevPage = toPageNavLink(prevPageDef);
const nextPage = toPageNavLink(nextPageDef);
const editSource = (currentPage?.source ?? sectionIndexSource(section))[locale];
const editUrl = `https://github.com/musistudio/claude-code-router/edit/main/docs/src/content/docs/${locale}/${editSource}`;
const isHome = pageKey === "documentation" && isSectionDoc;
const pageMarkdown = doc.rawContent();
---

<DocsLayout
  title={frontmatter.pageTitle ?? content.pageTitle}
  docTitle={frontmatter.title}
  isHome={isHome}
  description={frontmatter.lead ?? content.metaDescription}
  htmlLang={content.htmlLang}
  locale={locale}
  languageLabel={content.languageLabel}
  languageOptions={content.languageOptions}
  navItems={featuredNavItems}
  sidebarTree={sidebarTree}
  sidebarGroups={pageSidebarGroups}
  sidebarLinks={sidebarLinks}
  tocTitle={content.tocTitle}
  tocItems={tocItems}
  prevPage={prevPage}
  nextPage={nextPage}
  editUrl={editUrl}
  ui={content.ui}
>
  <article class="doc-article">
    {
      tocItems.length > 0 && (
        <details class="toc-inline">
          <summary>
            <List size={16} aria-hidden="true" />
            <span>{content.tocTitle}</span>
            <ChevronDown size={14} aria-hidden="true" />
          </summary>
          <nav>
            {tocItems.map((item) => {
              const depth = Math.min(Math.max(Number(item.depth), 2), 6);

              return (
                <a class={`toc-depth-${depth}`} href={item.href}>
                  {item.label}
                </a>
              );
            })}
          </nav>
        </details>
      )
    }
    <header class="article-header">
      <div>
        <p class="eyebrow">{frontmatter.eyebrow}</p>
        <h1>{frontmatter.title}</h1>
        <p class="lead">{frontmatter.lead}</p>
      </div>
      <button class="copy-page" type="button" data-copy-page>
        <Copy size={16} aria-hidden="true" />
        <span data-copy-label>{content.ui.copyPage}</span>
        <span class="copy-page-divider" aria-hidden="true" />
        <ChevronDown size={14} aria-hidden="true" />
      </button>
    </header>

    <div class="doc-markdown" data-markdown-content>
      <Content />
    </div>
  </article>

  <template data-code-icon-template>
    <span class="copy-icon" aria-hidden="true">
      <Copy size={18} />
    </span>
    <span class="success-icon" aria-hidden="true">
      <Check size={18} />
    </span>
  </template>

  <script define:vars={{
    pageMarkdown,
    copyPageLabel: content.ui.copyPage,
    copiedLabel: content.ui.copied,
    copyFailedLabel: content.ui.copyFailed,
    copyCodeLabel: content.ui.copyCode,
    copiedCodeLabel: content.ui.copiedCode,
    copyCodeFailedLabel: content.ui.copyCodeFailed,
  }}>
    const copyButton = document.querySelector("[data-copy-page]");
    const copyLabel = document.querySelector("[data-copy-label]");

    const writeClipboard = async (text) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.append(textarea);
      textarea.select();
      document.execCommand("copy");
      textarea.remove();
    };

    copyButton?.addEventListener("click", async () => {
      try {
        await writeClipboard(pageMarkdown);
        copyButton.classList.add("copied");
        if (copyLabel) copyLabel.textContent = copiedLabel;
      } catch {
        if (copyLabel) copyLabel.textContent = copyFailedLabel;
      }

      window.setTimeout(() => {
        copyButton.classList.remove("copied");
        if (copyLabel) copyLabel.textContent = copyPageLabel;
      }, 1800);
    });

    const codeIconTemplate = document.querySelector("[data-code-icon-template]");
    const buildCopyIcon = () => codeIconTemplate instanceof HTMLTemplateElement
      ? codeIconTemplate.innerHTML
      : "";

    document.querySelectorAll("[data-markdown-content] pre.astro-code").forEach((pre) => {
      if (!(pre instanceof HTMLElement) || pre.closest(".code-panel")) return;

      const language = pre.dataset.language || "text";
      const panel = document.createElement("div");
      panel.className = "code-panel markdown-code-panel";
      panel.setAttribute("aria-label", language);

      const toolbar = document.createElement("div");
      toolbar.className = "code-toolbar";

      const title = document.createElement("span");
      title.textContent = language === "text" ? "text" : language;

      const button = document.createElement("button");
      button.className = "code-copy";
      button.type = "button";
      button.dataset.copyCode = "";
      button.setAttribute("aria-label", copyCodeLabel);
      button.innerHTML = buildCopyIcon();

      const template = document.createElement("template");
      template.dataset.codeSource = "";
      template.textContent = pre.innerText.trimEnd();

      toolbar.append(title, button);
      panel.append(toolbar, template);
      pre.replaceWith(panel);
      panel.append(pre);
    });

    document.addEventListener("click", async (event) => {
      const button = event.target instanceof Element
        ? event.target.closest("[data-copy-code]")
        : null;

      if (!(button instanceof HTMLButtonElement)) return;

      const panel = button.closest(".code-panel");
      const source = panel?.querySelector("[data-code-source]");
      const text = source instanceof HTMLTemplateElement
        ? source.content.textContent ?? ""
        : source?.textContent ?? "";

      try {
        if (!text) throw new Error("No code content to copy");
        await writeClipboard(text);
        button.classList.add("copied");
        button.setAttribute("aria-label", copiedCodeLabel);
      } catch {
        button.classList.add("copy-failed");
        button.setAttribute("aria-label", copyCodeFailedLabel);
      }

      window.setTimeout(() => {
        button.classList.remove("copied", "copy-failed");
        button.setAttribute("aria-label", copyCodeLabel);
      }, 1600);
    });
  </script>
</DocsLayout>
