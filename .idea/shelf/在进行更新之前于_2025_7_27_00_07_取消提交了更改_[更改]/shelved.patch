+/**
+ * Opens a URL in the default browser in a cross-platform way
+ * @param url The URL to open
+ */
+export const openInBrowser = async (url: string) => {
+  const { spawn } = require('child_process');
+  const os = require('os');
+  
+  const platform = os.platform();
+  let command: string;
+  let args: string[];
+  
+  switch (platform) {
+    case 'darwin': // macOS
+      command = 'open';
+      args = [url];
+      break;
+    case 'win32': // Windows
+      command = 'cmd';
+      args = ['/c', 'start', url];
+      break;
+    case 'linux': // Linux
+      command = 'xdg-open';
+      args = [url];
+      break;
+    default:
+      throw new Error(`Unsupported platform: ${platform}`);
+  }
+  
+  return new Promise<void>((resolve, reject) => {
+    const process = spawn(command, args, { stdio: 'ignore' });
+    
+    process.on('error', (error: Error) => {
+      reject(new Error(`Failed to open browser: ${error.message}`));
+    });
+    
+    process.on('close', (code: number) => {
+      if (code === 0) {
+        resolve();
+      } else {
+        reject(new Error(`Browser opened failed with code: ${code}`));
+      }
+    });
+  });
+};
