      "surfaces": ["gateway"],
      "permissions": ["trusted-code", "gateway-routes", "proxy-routes", "http-backends"],
      "integrity": "sha256:53464f7a6fd97a931f807b282e08ac5b433014d2cde376a72df91e008f1fb28f",
